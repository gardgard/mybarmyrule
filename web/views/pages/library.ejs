<% const cats=[ { key:'all', label:'All', labelTh:'ทั้งหมด', icon:'fa-border-all' }, { key:'cocktail', label:'Cocktail',
  labelTh:'ค็อกเทล', icon:'fa-martini-glass-citrus' }, { key:'mocktail', label:'Mocktail', labelTh:'ม็อกเทล',
  icon:'fa-glass-water' }, { key:'wine', label:'Wine', labelTh:'ไวน์', icon:'fa-wine-glass' }, { key:'spirit',
  label:'Spirit', labelTh:'สุรา', icon:'fa-whiskey-glass' }, { key:'beer', label:'Beer', labelTh:'เบียร์',
  icon:'fa-beer-mug-empty' }, { key:'other', label:'Other', labelTh:'อื่นๆ', icon:'fa-flask' }, ]; const catColors={
  cocktail:'#3498DB', mocktail:'#4ECDC4', wine:'#C0392B', spirit:'#C9A84C', beer:'#F39C12', other:'#9B59B6' }; const
  catIcons={ cocktail:'fa-martini-glass-citrus', mocktail:'fa-glass-water', wine:'fa-wine-glass',
  spirit:'fa-whiskey-glass', beer:'fa-beer-mug-empty', other:'fa-flask' }; %>

  <div class="page-header">
    <h2 class="page-title" data-i18n="navLibrary">Library</h2>
    <% if (locals.userRole === 'admin') { %>
    <a href="/drinks/add" class="btn-primary"><i class="fa-solid fa-plus"></i> <span data-i18n="navAdd">Add Drink</span></a>
    <% } %>
  </div>

  <!-- Filter + Search Bar -->
  <div class="lib-toolbar">
    <form action="/drinks" method="GET" id="filterForm">
      <div class="cat-pills">
        <% cats.forEach(c=> { %>
          <button type="submit" name="category" value="<%= c.key %>"
            class="cat-pill <%= currentCategory === c.key ? 'active' : '' %> pill-<%= c.key %>">
            <i class="fa-solid <%= c.icon %>"></i>
            <span>
              <%= c.label %>
                <% if(c.key!=='all' && catCount[c.key]){ %> (<%= catCount[c.key] %>)<% } %>
            </span>
          </button>
          <% }); %>
      </div>

      <div class="lib-search-row">
        <div class="search-box">
          <i class="fa-solid fa-magnifying-glass"></i>
          <input type="text" name="search" value="<%= search %>" data-i18n-placeholder="searchPlaceholder"
            placeholder="ค้นหา...">
        </div>
        <select name="sort" class="sort-select" onchange="this.form.submit()">
          <option value="newest" <%=sort==='newest' ? 'selected' :'' %>>Newest</option>
          <option value="rating" <%=sort==='rating' ? 'selected' :'' %>>Top Rated</option>
          <option value="name" <%=sort==='name' ? 'selected' :'' %>>A-Z</option>
          <option value="price" <%=sort==='price' ? 'selected' :'' %>>Price ↓</option>
          <option value="oldest" <%=sort==='oldest' ? 'selected' :'' %>>Oldest</option>
        </select>
        <% if (currentCategory !=='all' || search || currentCollection || currentSubcategory || f_sweet || f_body ||
          f_sour) { %>
          <a href="/drinks" class="btn-ghost">Clear</a>
          <% } %>
            <% if (currentCollection) { %>
              <button type="button" onclick="document.getElementById('addDrinkModal').style.display='flex'"
                style="background:var(--gold); color:#000; padding:0.4rem 1rem; border-radius:20px; border:none; font-weight:600; cursor:pointer; font-size:0.85rem; display:flex; align-items:center; gap:6px; margin-left:auto;">
                <i class="fa-solid fa-plus-circle"></i> ดึงเครื่องดื่มมาใส่
              </button>
              <% } %>
      </div>

      <!-- Advanced Filters -->
      <div class="advanced-filters"
        style="display:flex; flex-wrap:wrap; gap:0.5rem; margin-top:1rem; padding-top:1rem; border-top:1px solid rgba(255,255,255,0.05);">

        <% if (typeof subcategories !=='undefined' && subcategories.length> 0) { %>
          <div class="pill-select-wrap">
            <select name="subcategory" class="pill-select <%= currentSubcategory ? 'active' : '' %>"
              onchange="this.form.submit()">
              <option value="">-- หมวดหมู่ย่อย --</option>
              <% subcategories.forEach(sub=> { %>
                <option value="<%= sub %>" <%=currentSubcategory===sub ? 'selected' : '' %>><%= sub %>
                </option>
                <% }) %>
            </select>
          </div>
          <% } %>

            <div class="pill-select-wrap">
              <select name="f_sweet" class="pill-select <%= f_sweet ? 'active' : '' %>" onchange="this.form.submit()">
                <option value="" data-i18n="sweetness">ความหวาน</option>
                <% for(let i=1;i<=5;i++){ %>
                  <option value="<%= i %>" <%=f_sweet==i ? 'selected' : '' %>>ระดับ <%= i %>
                  </option>
                  <% } %>
              </select>
            </div>

            <div class="pill-select-wrap">
              <select name="f_body" class="pill-select <%= f_body ? 'active' : '' %>" onchange="this.form.submit()">
                <option value="" data-i18n="body">บอดี้ / ความหนัก</option>
                <% for(let i=1;i<=5;i++){ %>
                  <option value="<%= i %>" <%=f_body==i ? 'selected' : '' %>>ระดับ <%= i %>
                  </option>
                  <% } %>
              </select>
            </div>

            <div class="pill-select-wrap">
              <select name="f_sour" class="pill-select <%= f_sour ? 'active' : '' %>" onchange="this.form.submit()">
                <option value="" data-i18n="sourness">ความเปรี้ยว</option>
                <% for(let i=1;i<=5;i++){ %>
                  <option value="<%= i %>" <%=f_sour==i ? 'selected' : '' %>>ระดับ <%= i %>
                  </option>
                  <% } %>
              </select>
            </div>

      </div>
    </form>
  </div>

  <!-- Drinks Grid -->
  <% if (drinks.length===0) { %>
    <div class="empty-state" style="display:flex; flex-direction:column; align-items:center; justify-content:center; text-align:center; min-height:300px; width:100%;">
      <div class="empty-icon" style="margin-bottom:20px;">
        <img src="/images/logo.png" style="width:120px; height:120px; object-fit:contain; opacity:0.3; filter:grayscale(1) brightness(2);">
      </div>
      <p data-i18n="noResults" style="margin-bottom:20px; font-size:1.1rem; color:var(--text2);">ไม่พบเครื่องดื่ม</p>
      <% if (locals.userRole === 'admin') { %>
      <a href="/drinks/add" class="btn-primary" style="padding: 10px 25px;">+ Add First Drink</a>
      <% } %>
    </div>
    <% } else { %>
      <div class="drinks-grid">
        <% drinks.forEach(d=> {
          const color = catColors[d.category] || '#9B59B6';
          const icon = catIcons[d.category] || 'fa-flask';
          %>
          <a href="/drinks/<%= d.id %>" class="drink-card">
            <div class="drink-card-img">
              <% if (d.image_path) { %>
                <img src="<%= d.image_path %>" alt="<%= d.name_th %>" loading="lazy">
                <% } else { %>
                  <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,0.2); padding:20px;">
                    <img src="/images/logo.png" alt="Default" style="width:100%; height:100%; object-fit:contain; opacity:0.5;">
                  </div>
                  <% } %>

            </div>
            <div class="drink-card-body">
              <div class="card-cat-badge badge-<%= d.category %>" style="text-transform: capitalize;">
                <%= d.category %>
              </div>
              <div class="card-name">
                <%= d.name_th %>
              </div>
              <% if (d.name_en) { %>
                <div class="card-name-en">
                  <%= d.name_en %>
                </div>
                <% } %>
                  <% if (d.brand) { %>
                    <div class="card-brand">
                      <%= d.brand %>
                        <% if(d.country){ %> · <%= d.country %>
                            <% } %>
                    </div>
                    <% } %>
                      <div class="card-footer">
                        <div class="card-stars">
                          <% for(let i=1;i<=5;i++){ %><i class="fa-solid fa-star"
                              style="color:<%= i<=d.rating ? '#C9A84C':'#2A2018' %>"></i>
                            <% } %>
                        </div>
                        <div class="card-price">
                          <% if(locals.userRole === 'admin' && d.price_sell > 0){ %>
                            ฿<%= d.price_sell %>
                          <% } else { %>
                            <span style="font-size: 0.7rem; color: var(--text3); font-weight: normal;">
                              <i class="fa-regular fa-calendar-days"></i> <%= new Date(d.created_at).toLocaleDateString('en-GB', {day:'numeric', month:'short', year:'2-digit'}) %>
                            </span>
                          <% } %>
                        </div>
                      </div>
            </div>
          </a>
          <% }); %>
      </div>
      <% } %>

        <% if (currentCollection) { %>
          <!-- Modal: Add Existing Drink to Collection -->
          <div id="addDrinkModal"
            style="display:none; position:fixed; top:0; left:0; width:100%; height:100%; background:rgba(0,0,0,0.8); z-index:9999; align-items:center; justify-content:center; backdrop-filter:blur(5px);">
            <div
              style="background:var(--bg2); border:1px solid rgba(255,255,255,0.1); border-radius:16px; width:90%; max-width:500px; max-height:80vh; display:flex; flex-direction:column; box-shadow:0 10px 30px rgba(0,0,0,0.5);">
              <div
                style="padding:1.5rem; border-bottom:1px solid rgba(255,255,255,0.1); display:flex; justify-content:space-between; align-items:center;">
                <h3 style="margin:0; font-size:1.2rem; color:var(--gold);">เพิ่มเครื่องดื่มลงหมวดหมู่นี้</h3>
                <button type="button" onclick="document.getElementById('addDrinkModal').style.display='none'"
                  style="background:none; border:none; color:var(--text3); cursor:pointer; font-size:1.2rem; transition:0.2s;"
                  onmouseover="this.style.color='#fff'" onmouseout="this.style.color='var(--text3)'"><i
                    class="fa-solid fa-times"></i></button>
              </div>
              <div style="padding:1rem; border-bottom:1px solid rgba(255,255,255,0.05);">
                <input type="text" id="modalSearch" onkeyup="filterModalDrinks()" placeholder="ค้นหาชื่อเครื่องดื่ม..."
                  style="width:100%; padding:0.6rem 1rem; background:rgba(255,255,255,0.05); border:1px solid rgba(255,255,255,0.1); border-radius:8px; color:var(--text); outline:none; font-family:inherit;">
              </div>
              <div id="modalDrinkList"
                style="padding:1rem; overflow-y:auto; display:flex; flex-direction:column; gap:0.5rem;">
                <% if (typeof drinksNotInCollection !=='undefined' && drinksNotInCollection.length> 0) { %>
                  <% drinksNotInCollection.forEach(d=> { %>
                    <div class="modal-drink-item"
                      style="display:flex; justify-content:space-between; align-items:center; background:rgba(255,255,255,0.02); padding:0.8rem 1rem; border-radius:12px; border:1px solid rgba(255,255,255,0.05);">
                      <div style="display:flex; align-items:center; gap:12px;">
                        <% if (d.image_path) { %>
                          <img src="<%= d.image_path %>"
                            style="width:40px; height:40px; object-fit:cover; border-radius:8px;">
                          <% } else { %>
                            <div
                              style="width:40px; height:40px; background:rgba(255,255,255,0.1); border-radius:8px; display:flex; align-items:center; justify-content:center;">
                              <i class="fa-solid fa-wine-glass" style="color:var(--text3)"></i></div>
                            <% } %>
                              <div>
                                <div style="font-weight:600; font-size:0.95rem;">
                                  <%= d.name_th %>
                                </div>
                                <div style="font-size:0.8rem; color:var(--gold); opacity:0.8;">
                                  <%= d.category.charAt(0).toUpperCase() + d.category.slice(1) %>
                                </div>
                              </div>
                      </div>
                      <form action="/collections/<%= currentCollection %>/add-drink" method="POST" style="margin:0;">
                        <input type="hidden" name="drink_id" value="<%= d.id %>">
                        <input type="hidden" name="return_to" value="/drinks?collection_id=<%= currentCollection %>">
                        <button type="submit"
                          style="background:rgba(201, 168, 76, 0.1); color:var(--gold); border:1px solid rgba(201, 168, 76, 0.3); padding:0.4rem 0.8rem; border-radius:20px; font-size:0.8rem; cursor:pointer; transition:0.2s;"
                          onmouseover="this.style.background='var(--gold)'; this.style.color='#000';"
                          onmouseout="this.style.background='rgba(201, 168, 76, 0.1)'; this.style.color='var(--gold)';">
                          <i class="fa-solid fa-plus"></i> เพิ่ม
                        </button>
                      </form>
                    </div>
                    <% }) %>
                      <% } else { %>
                        <div style="text-align:center; color:var(--text3); padding:3rem 0;">
                          <i class="fa-solid fa-check-circle"
                            style="font-size:2rem; opacity:0.5; margin-bottom:1rem; display:block;"></i>
                          ไม่มีเครื่องดื่มอื่นให้เพิ่มแล้ว
                        </div>
                        <% } %>
              </div>
            </div>
          </div>
          <script>
            function filterModalDrinks() {
              const input = document.getElementById('modalSearch');
              const filter = input.value.toLowerCase();
              const list = document.getElementById('modalDrinkList');
              const items = list.getElementsByClassName('modal-drink-item');

              for (let i = 0; i < items.length; i++) {
                const text = items[i].textContent || items[i].innerText;
                if (text.toLowerCase().indexOf(filter) > -1) {
                  items[i].style.display = "flex";
                } else {
                  items[i].style.display = "none";
                }
              }
            }
          </script>
          <% } %>