<div class="page-header">
  <h2 class="page-title"><i class="fa-solid fa-layer-group" style="color:#C9A84C"></i> <span data-i18n="navCollections">Collections</span></h2>
  <button class="btn-primary" onclick="document.getElementById('addCollectionModal').style.display='flex'"><i class="fa-solid fa-plus"></i> <span data-i18n="addCollection">Create Collection</span></button>
</div>

<div class="library-grid" style="margin-top:2rem">
  <% collections.forEach(c => { %>
    <a href="/collections/<%= c.id %>" class="drink-card" style="text-decoration:none">
      <div class="drink-img-wrap">
        <% if (c.cover_image) { %>
          <img src="<%= c.cover_image %>" class="drink-img" style="object-fit:cover" alt="<%= c.name %>">
        <% } else if (c.first_drink_img) { %>
          <img src="<%= c.first_drink_img %>" class="drink-img" style="object-fit:cover" alt="<%= c.name %>">
        <% } else { %>
          <div style="width:100%; height:100%; display:flex; align-items:center; justify-content:center; background:rgba(0,0,0,0.2); padding:20px;">
            <img src="/images/logo.png" style="width:60%; height:60%; object-fit:contain; opacity:0.2;">
          </div>
        <% } %>
      </div>
      <div class="drink-info">
        <div style="display:flex; justify-content:space-between; align-items:flex-start;">
          <h3 class="drink-name" style="color:#C9A84C; margin:0;"><%= c.name %></h3>
          <form action="/collections/<%= c.id %>/delete" method="POST" onsubmit="return confirm('ลบหมวดหมู่นี้? (ข้อมูลเครื่องดื่มจะไม่หายไป)')" style="margin:0;">
            <button type="submit" style="background:none; border:none; color:var(--text3); cursor:pointer; padding:2px 5px; transition:0.2s;" onmouseover="this.style.color='#FF6B6B'" onmouseout="this.style.color='var(--text3)'">
              <i class="fa-solid fa-trash-can" style="font-size:0.9rem;"></i>
            </button>
          </form>
        </div>
        <% if (c.description) { %><p class="drink-brand" style="opacity:0.8; margin-top:0.25rem;"><%= c.description %></p><% } %>
        <p style="font-size:0.8rem; color:var(--text3); margin-top:0.5rem"><i class="fa-solid fa-martini-glass"></i> <%= c.drink_count %> Drinks</p>
      </div>
    </a>
  <% }) %>
</div>

<!-- Add Collection Modal -->
<div id="addCollectionModal" class="modal-overlay">
  <div class="modal-box" style="max-width:400px">
    <div class="modal-header">
      <h3>สร้าง Collection ใหม่</h3>
      <button type="button" class="modal-close" onclick="document.getElementById('addCollectionModal').style.display='none'"><i class="fa-solid fa-xmark"></i></button>
    </div>
    <form action="/collections/add" method="POST" enctype="multipart/form-data">
      <div class="modal-body">
        <div class="form-group">
          <label>ชื่อ Collection (เช่น Signature Menu)</label>
          <input type="text" name="name" required placeholder="ชื่อกลุ่มเครื่องดื่ม">
        </div>
        <div class="form-group">
          <label>รายละเอียด</label>
          <input type="text" name="description" placeholder="อธิบายสั้นๆ">
        </div>
        <div class="form-group">
          <label>รูปภาพหน้าปก</label>
          <input type="file" name="cover_image" accept="image/*">
        </div>
      </div>
      <div class="modal-footer">
        <button type="submit" class="btn-primary">สร้างเลย</button>
      </div>
    </form>
  </div>
</div>
